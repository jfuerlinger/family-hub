# Family Hub – Deployment-Umgebungsvariablen
#
# Diese Datei nach .env.deploy kopieren und die Werte anpassen:
#   cp .env.deploy.example .env.deploy

# DockerHub-Benutzername (z.B. "myuser")
DOCKERHUB_USERNAME=

# Image-Tag (z.B. "latest" oder "v1.0.0")
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=familyhubdb

# JWT (mindestens 32 Zeichen)
JWT_SIGNING_KEY=change-me-to-a-long-random-secret

# Ports
BACKEND_PORT=8080
FRONTEND_PORT=4173

# Frontend → Backend-URL (intern im Docker-Netzwerk)
FRONTEND_BACKEND_URL=http://backend:8080

# Traefik (optional, nur mit docker-compose.traefik.yml)
TRAEFIK_HOST=familyhub.example.com
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
